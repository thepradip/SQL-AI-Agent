# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Database — any SQLAlchemy-compatible async URL
DATABASE_URL=sqlite+aiosqlite:///./health.db

# Optional: PII columns for SQLAS safety scoring (comma-separated)
# PII_COLUMNS=email,phone,ssn

# Optional: domain hint for better LLM context
# DOMAIN_HINT=This is a healthcare analytics database with patient demographics and activity logs.

# Optional: CORS frontend URL
# FRONTEND_URL=http://localhost:5173
